{
  "name": "anicode",
  "version": "0.1.0",
  "description": "anicode —— 前端无关的自研 AI coding agent 的终端界面（TUI）",
  "type": "module",
  "bin": {
    "anicode": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/cli.tsx",
    "build": "node esbuild.mjs",
    "prepublishOnly": "node esbuild.mjs --production",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test 'src/**/*.test.tsx'"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@anicode/core": "*",
    "@anicode/shared": "*",
    "@types/react": "^18.3.0",
    "esbuild": "^0.28.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.0"
  }
}
